# Copy this file to .env and fill in your own values.
# Never commit the real .env file.

# Required - OpenAI key used for embeddings and chat completion
OPENAI_API_KEY=your_openai_api_key_here

# Graph RAG mode
# false (default) = use local NetworkX fallback graph, no external DB needed
# true            = use Neo4j AuraDB (requires NEO4J_* values below)
USE_NEO4J=false

# Optional - Neo4j AuraDB (only needed when USE_NEO4J=true)
NEO4J_URI=neo4j+s://your-aura-uri.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=your_aura_instance_id
AURA_INSTANCENAME=your_aura_instance_name

# Optional - LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=TN-Scheme-Navigator-AI
